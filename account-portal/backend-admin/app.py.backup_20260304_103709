from flask import Flask
from dotenv import load_dotenv
from routes.regions import regions_bp
from routes.instances import instances_bp
from routes.create_account import create_account_bp
from routes.sso_routes import sso_bp
from routes.update_role import update_role_bp
from routes.delete_account import delete_account_bp
from routes.logs import logs_bp
from routes.accounts import accounts_bp
from routes.project_groups import project_groups_bp
from routes.onboarding import onboarding_bp
from routes.auth import auth_bp
from routes.github_routes import github_bp
from routes.user_access_logs import user_access_logs_bp
from routes.audit_logs import audit_logs_bp
from routes.cost_monitoring import cost_monitoring_bp
from routes.finops_routes import finops_bp

load_dotenv()

app = Flask(__name__)

app.register_blueprint(regions_bp)
app.register_blueprint(instances_bp)
app.register_blueprint(create_account_bp)
app.register_blueprint(update_role_bp)
app.register_blueprint(delete_account_bp)
app.register_blueprint(logs_bp)
app.register_blueprint(accounts_bp)
app.register_blueprint(project_groups_bp)
app.register_blueprint(onboarding_bp)
app.register_blueprint(auth_bp)
app.register_blueprint(github_bp, url_prefix='/api/github')
app.register_blueprint(user_access_logs_bp)
app.register_blueprint(audit_logs_bp)
app.register_blueprint(sso_bp)
app.register_blueprint(finops_bp)
app.register_blueprint(cost_monitoring_bp, url_prefix='/api/cost-monitoring')

@app.errorhandler(Exception)
def handle_exception(e):
    import traceback
    traceback.print_exc()
    return str(e), 500

import boto3
try:
    boto3.client('sts').get_caller_identity()
    print('AWS credentials initialized')
except:
    print('AWS credentials not available')

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
