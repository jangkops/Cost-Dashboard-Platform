@sso_bp.route('/api/sso-status/<email>', methods=['GET'])
def check_sso_status(email):
    """SSO 사용자 상태 확인"""
    
    try:
        import boto3
        
        session = boto3.Session(
            aws_access_key_id=os.getenv('MG_INFRA_ACCESS_KEY'),
            aws_secret_access_key=os.getenv('MG_INFRA_SECRET_KEY'),
            region_name='us-east-1'
        )
        identitystore = session.client('identitystore')
        identity_store_id = 'd-906617189d'
        
        # 사용자 검색
        response = identitystore.list_users(
            IdentityStoreId=identity_store_id,
            Filters=[{
                'AttributePath': 'UserName',
                'AttributeValue': email
            }]
        )
        
        if response['Users']:
            user = response['Users'][0]
            return jsonify({
                'exists': True,
                'user_id': user['UserId'],
                'username': user['UserName'],
                'display_name': user['DisplayName']
            })
        else:
            return jsonify({'exists': False})
            
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@sso_bp.route('/api/verify-email', methods=['POST'])
def verify_email():
    """이메일 확인 처리 - 완전 자동화"""
    
    data = request.get_json()
    token = data.get('token', '').strip()
    email = data.get('email', '').strip()
    
    if not token or not email:
        return jsonify({'error': 'Token and email required'}), 400
    
    try:
        import hashlib
        import json
        from datetime import datetime
        
        # 토큰 해시 생성
        token_hash = hashlib.sha256(token.encode()).hexdigest()
        
        # 토큰 파일에서 확인
        try:
            with open(f'/tmp/verify_{token_hash[:16]}.json', 'r') as f:
                token_data = json.load(f)
        except FileNotFoundError:
            return jsonify({'error': 'Invalid or expired token'}), 400
        
        # 토큰 유효성 검사
        if token_data['email'] != email:
            return jsonify({'error': 'Token does not match email'}), 400
        
        if datetime.now() > datetime.fromisoformat(token_data['expires']):
            return jsonify({'error': 'Token has expired'}), 400
        
        if token_data['verified']:
            return jsonify({'error': 'Email already verified'}), 400
        
        # AWS Identity Store에서 사용자 이메일 확인 상태 업데이트
        import boto3
        
        session = boto3.Session(
            aws_access_key_id=os.getenv('MG_INFRA_ACCESS_KEY'),
            aws_secret_access_key=os.getenv('MG_INFRA_SECRET_KEY'),
            region_name='us-east-1'
        )
        identitystore = session.client('identitystore')
        identity_store_id = 'd-906617189d'
        
        # 사용자 이메일 확인 완료 처리
        user_id = token_data['user_id']
        
        # 토큰을 확인됨으로 표시
        token_data['verified'] = True
        token_data['verified_at'] = datetime.now().isoformat()
        
        with open(f'/tmp/verify_{token_hash[:16]}.json', 'w') as f:
            json.dump(token_data, f)
        
        # 확인 완료 이메일 발송
        try:
            ses = session.client('ses', region_name='us-east-1')
            
            welcome_email = f"""
<!DOCTYPE html>
