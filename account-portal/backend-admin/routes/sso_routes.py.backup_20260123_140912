from flask import Blueprint, request, jsonify
import subprocess
import json
import os
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart

sso_bp = Blueprint('sso', __name__)


def send_outlook_email(to_email, subject, body):
    """Outlook SMTP로 이메일 발송"""
    try:
        outlook_email = os.getenv('OUTLOOK_EMAIL', 'changgeun.jang@mogam.re.kr')
        outlook_password = os.getenv('OUTLOOK_PASSWORD')
        
        if not outlook_password:
            print("ERROR: OUTLOOK_PASSWORD not set")
            return False
        
        msg = MIMEMultipart()
        msg['From'] = outlook_email
        msg['To'] = to_email
        msg['Subject'] = subject
        msg.attach(MIMEText(body, 'plain', 'utf-8'))
        
        server = smtplib.SMTP('smtp.office365.com', 587)
        server.starttls()
        server.login(outlook_email, outlook_password)
        server.send_message(msg)
        server.quit()
        
        print(f"Email sent successfully to {to_email}")
        return True
    except Exception as e:
        print(f"Outlook SMTP error: {e}")
        return False

