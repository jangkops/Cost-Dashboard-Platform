import os
import requests
from typing import List, Dict
from datetime import datetime, timedelta

class GitHubService:
    def __init__(self):
        self.token = os.getenv('GITHUB_TOKEN')
        self.headers = {
            'Authorization': f'token {self.token}',
            'Accept': 'application/vnd.github.v3+json'
        }
        self.base_url = 'https://api.github.com'
        self.default_org = 'mogam-ai'
    
    def get_authenticated_user(self) -> Dict:
        response = requests.get(f'{self.base_url}/user', headers=self.headers)
        response.raise_for_status()
        return response.json()
    
    def get_organizations(self) -> List[Dict]:
        try:
            response = requests.get(f'{self.base_url}/orgs/{self.default_org}', headers=self.headers)
            response.raise_for_status()
            return [response.json()]
        except:
            return []
    
    def get_org_members(self, org: str) -> List[Dict]:
        response = requests.get(f'{self.base_url}/orgs/{org}/members', headers=self.headers)
        response.raise_for_status()
        return response.json()
    
    def get_org_teams(self, org: str) -> List[Dict]:
        response = requests.get(f'{self.base_url}/orgs/{org}/teams', headers=self.headers)
        response.raise_for_status()
        return response.json()
    
    def get_org_repos(self, org: str) -> List[Dict]:
        response = requests.get(f'{self.base_url}/orgs/{org}/repos?per_page=100', headers=self.headers)
        response.raise_for_status()
        return response.json()
    
    def get_team_members(self, org: str, team_slug: str) -> List[Dict]:
        response = requests.get(f'{self.base_url}/orgs/{org}/teams/{team_slug}/members', headers=self.headers)
        response.raise_for_status()
        return response.json()
    
    def get_repo_collaborators(self, owner: str, repo: str) -> List[Dict]:
        response = requests.get(f'{self.base_url}/repos/{owner}/{repo}/collaborators', headers=self.headers)
        response.raise_for_status()
        return response.json()
    
    def get_repo_permissions(self, owner: str, repo: str) -> List[Dict]:
        """Get repository collaborators with their permission levels (READ ONLY)"""
        response = requests.get(
            f'{self.base_url}/repos/{owner}/{repo}/collaborators',
            headers=self.headers,
            params={'affiliation': 'all', 'per_page': 100}
        )
        response.raise_for_status()
        collabs = response.json()
        
        result = []
        for collab in collabs:
            perm_response = requests.get(
                f'{self.base_url}/repos/{owner}/{repo}/collaborators/{collab["login"]}/permission',
                headers=self.headers
            )
            if perm_response.status_code == 200:
                perm_data = perm_response.json()
                result.append({
                    'login': collab['login'],
                    'avatar_url': collab['avatar_url'],
                    'permission': perm_data.get('permission', 'unknown'),
                    'role_name': perm_data.get('role_name', 'N/A')
                })
        return result
    
    def get_team_repos(self, org: str, team_slug: str) -> List[Dict]:
        """Get repositories accessible by a team (READ ONLY)"""
        response = requests.get(
            f'{self.base_url}/orgs/{org}/teams/{team_slug}/repos',
            headers=self.headers,
            params={'per_page': 100}
        )
        response.raise_for_status()
        return response.json()
    
    def get_repo_events(self, owner: str, repo: str, days: int = 7) -> List[Dict]:
        """Get repository events (push, clone activity) (READ ONLY)"""
        response = requests.get(
            f'{self.base_url}/repos/{owner}/{repo}/events',
            headers=self.headers,
            params={'per_page': 100}
        )
        response.raise_for_status()
        events = response.json()
        
        cutoff = datetime.now() - timedelta(days=days)
        filtered = []
        for event in events:
            event_time = datetime.strptime(event['created_at'], '%Y-%m-%dT%H:%M:%SZ')
            if event_time >= cutoff:
                filtered.append({
                    'type': event['type'],
                    'actor': event['actor']['login'],
                    'created_at': event['created_at'],
                    'payload': event.get('payload', {})
                })
        return filtered
    
    def get_org_audit_log(self, org: str, days: int = 7) -> List[Dict]:
        """Get organization audit log (READ ONLY - requires admin:org scope)"""
        try:
            response = requests.get(
                f'{self.base_url}/orgs/{org}/audit-log',
                headers=self.headers,
                params={'per_page': 100}
            )
            if response.status_code == 200:
                return response.json()
            return []
        except:
            return []
    
    def add_team_member(self, org: str, team_slug: str, username: str, role: str = 'member') -> Dict:
        """Add member to team (WRITE - requires admin:org)"""
        response = requests.put(
            f'{self.base_url}/orgs/{org}/teams/{team_slug}/memberships/{username}',
            headers=self.headers,
            json={'role': role}
        )
        response.raise_for_status()
        return response.json()
    
    def remove_team_member(self, org: str, team_slug: str, username: str) -> bool:
        """Remove member from team (WRITE - requires admin:org)"""
        response = requests.delete(
            f'{self.base_url}/orgs/{org}/teams/{team_slug}/memberships/{username}',
            headers=self.headers
        )
        return response.status_code == 204
    
    def add_repo_to_team(self, org: str, team_slug: str, owner: str, repo: str, permission: str = 'pull') -> bool:
        """Add repository to team with permission (WRITE - requires admin:org)"""
        response = requests.put(
            f'{self.base_url}/orgs/{org}/teams/{team_slug}/repos/{owner}/{repo}',
            headers=self.headers,
            json={'permission': permission}
        )
        return response.status_code == 204
    
    def remove_repo_from_team(self, org: str, team_slug: str, owner: str, repo: str) -> bool:
        """Remove repository from team (WRITE - requires admin:org)"""
        response = requests.delete(
            f'{self.base_url}/orgs/{org}/teams/{team_slug}/repos/{owner}/{repo}',
            headers=self.headers
        )
        return response.status_code == 204
