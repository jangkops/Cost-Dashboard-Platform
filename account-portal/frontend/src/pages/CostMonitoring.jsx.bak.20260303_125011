                <thead><tr className="bg-gray-50"><th className="px-3 py-2 text-left">{settingsTab === 'project_code_mapping' ? '프로젝트 코드' : settingsTab === 'project_name_to_code' ? '프로젝트명 (별칭)' : settingsTab === 'uid_to_username' ? 'UID' : '인스턴스 ID'}</th><th className="px-3 py-2 text-left">{settingsTab === 'project_code_mapping' ? '설명' : settingsTab === 'project_name_to_code' ? '프로젝트 코드' : '이름'}</th><th className="px-3 py-2 w-16"></th></tr></thead>
                <tbody>
                  {(() => {
                    const entries = Object.entries(editingMappings[settingsTab] || {});
                    if (settingsTab === 'project_name_to_code') {
                      // 프로젝트 별칭: 코드별로 그룹핑 후 정렬
                      entries.sort((a, b) => {
                        if (a[1] !== b[1]) return a[1].localeCompare(b[1]); // 코드 순
                        return a[0].localeCompare(b[0]); // 같은 코드 내에서 별칭 순
                      });
                    } else if (settingsTab === 'project_code_mapping') {
                      // 프로젝트 코드: 코드 순
                      entries.sort((a, b) => a[0].localeCompare(b[0]));
                    }
                    const filtered = searchMapping.trim()                       ? entries.filter(([k, v]) =>                           k.toLowerCase().includes(searchMapping.toLowerCase()) ||                           v.toLowerCase().includes(searchMapping.toLowerCase())                         )                       : entries;                    return filtered;
                  })().map(([k, v]) => (
                    <tr key={k} className="border-b border-gray-100 hover:bg-gray-50">
                      <td className="px-3 py-1.5 font-mono text-xs">{k}</td>
                      <td className="px-3 py-1.5"><input value={v} onChange={e => { const m = {...editingMappings}; m[settingsTab] = {...m[settingsTab], [k]: e.target.value}; setEditingMappings(m); }} className="w-full border border-gray-200 rounded px-2 py-1 text-sm focus:outline-none focus:border-indigo-400" /></td>
                      <td className="px-3 py-1.5 text-center"><button onClick={() => { const m = {...editingMappings}; const t = {...m[settingsTab]}; delete t[k]; m[settingsTab] = t; setEditingMappings(m); }} className="text-red-400 hover:text-red-600 text-xs">삭제</button></td>
                    </tr>
                  ))}
                  <tr className="bg-blue-50/50">
                    <td className="px-3 py-1.5"><input value={newKey} onChange={e => setNewKey(e.target.value)} placeholder="키 입력 (대소문자 구분)" className="w-full border border-gray-200 rounded px-2 py-1 text-sm focus:outline-none focus:border-indigo-400" /></td>
                    <td className="px-3 py-1.5"><input value={newVal} onChange={e => setNewVal(e.target.value)} placeholder="값 입력" className="w-full border border-gray-200 rounded px-2 py-1 text-sm focus:outline-none focus:border-indigo-400" /></td>
                    <td className="px-3 py-1.5 text-center"><button onClick={() => { if(newKey.trim()){ const m={...editingMappings}; m[settingsTab]={...m[settingsTab],[newKey.trim()]:newVal}; console.log('Added', newKey.trim(), '->', newVal, 'Total:', Object.keys(m[settingsTab]).length); setEditingMappings(m); setNewKey(''); setNewVal(''); }}} className="text-blue-500 hover:text-blue-700 text-xs font-semibold">추가</button></td>
                  </tr>
                </tbody>
              </table>
            </div>
            <div className="flex justify-between items-center px-6 py-4 border-t bg-gray-50 rounded-b-2xl">
              <span className="text-xs text-gray-400">{Object.keys(editingMappings[settingsTab] || {}).length}개 항목</span>
              <div className="flex gap-2">
                <button onClick={() => setShowSettings(false)} className="px-4 py-2 text-sm text-gray-600 bg-white border rounded-lg hover:bg-gray-50">취소</button>
                <button disabled={savingMappings} onClick={async () => { setSavingMappings(true); const tabs = ['project_name_to_code', 'project_code_mapping', 'uid_to_username', 'instance_names']; for (const tab of tabs) { await fetch('/api/cost-monitoring/mappings/' + tab, {method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(editingMappings[tab])}); } setMappings(JSON.parse(JSON.stringify(editingMappings))); setSavingMappings(false); alert('저장 완료.\n\n캐시가 초기화되었습니다.\n첫 조회 시 2~3분 소요될 수 있습니다.'); setShowSettings(false); setData(null); loadData(); }} className="px-4 py-2 text-sm text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 disabled:bg-gray-300">{savingMappings ? '저장 중...' : '저장'}</button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

