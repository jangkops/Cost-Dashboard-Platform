import React, { useState, useEffect, useMemo } from "react";
import XLSX from "xlsx-js-style";

export default function CostMonitoring() {
  // KST 기준 날짜 생성 함수
  const getKSTDate = (daysOffset = 0) => {
    const kstDate = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Seoul' }));
    kstDate.setDate(kstDate.getDate() + daysOffset);
    const year = kstDate.getFullYear();
    const month = String(kstDate.getMonth() + 1).padStart(2, '0');
    const day = String(kstDate.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  };
  
  const [currency, setCurrency] = useState('KRW');
  const [selectedDate, setSelectedDate] = useState(getKSTDate(-2)); // 48시간 전
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(false);
  const [viewMode, setViewMode] = useState('project');
  const [calendarMonth, setCalendarMonth] = useState(getKSTDate().slice(0,7));
  const [viewType, setViewType] = useState('daily');
  const [selectedMonth, setSelectedMonth] = useState(null);
  const [hovered, setHovered] = useState(null);
  const [showSettings, setShowSettings] = useState(false);
  const [mappings, setMappings] = useState(null);
  const [settingsTab, setSettingsTab] = useState('project_code_mapping');
  const [editingMappings, setEditingMappings] = useState(null);
  const [newKey, setNewKey] = useState('');
  const [newVal, setNewVal] = useState('');
  const [savingMappings, setSavingMappings] = useState(false);
  const [searchMapping, setSearchMapping] = useState('');
  const [showSlowLoadingMsg, setShowSlowLoadingMsg] = useState(false);
  const [search, setSearch] = useState("");

  useEffect(() => { loadData(); }, [selectedDate, viewType, selectedMonth, calendarMonth]);


  const loadData = async () => {
    setLoading(true);
    setData(null);
    setShowSlowLoadingMsg(false);
    const slowTimer = setTimeout(() => setShowSlowLoadingMsg(true), 10000);
    try {
      let url;
      if (viewType === 'monthly' && selectedMonth) {
        const [y] = calendarMonth.split('-');
        url = `/api/cost-monitoring/monthly-costs/${y}/${selectedMonth}`;
      } else {
        const dateToUse = selectedDate || new Date(Date.now() + 9*60*60*1000).toISOString().slice(0,10);
        url = '/api/cost-monitoring/daily-costs/' + dateToUse;
      }
      const res = await fetch(url, {
        cache: 'no-store',
        headers: { 'Cache-Control': 'no-cache' }
      });
      if (res.ok) {
        const result = await res.json();
        console.log('API Response:', result.date, 'Total:', result.total_cost);
        const transformed = {
          ...result,
          projects: (result.projects || []).map(p => ({
            ...p,
            cost_usd: p.total_cost,
            cost_krw: p.total_cost * 1440,
            code: p.code || p.project,
            description: p.description
          })),
          users: (result.users || []).map(u => ({
            ...u,
            cost_usd: u.total_cost,
            cost_krw: u.total_cost * 1440,
            name: u.username
          }))
        };
        setData(transformed);
      } else {
        setData(null);
      }
    } catch (e) { 
      setData(null);
    }
    clearTimeout(slowTimer);
    setLoading(false);
  };

  const fmt = (usd, krw) => {
    if (currency === 'KRW') return krw ? '₩' + Math.round(krw).toLocaleString() : '₩0';
    return usd ? '$' + usd.toFixed(2) : '$0.00';
  };

  const colors = ['#6366f1','#8b5cf6','#ec4899','#f43f5e','#f97316','#eab308','#22c55e','#14b8a6','#06b6d4','#3b82f6'];
  const instColors = {G5:'#6366f1',R7:'#22c55e',P4D:'#f43f5e',P4DE:'#8b5cf6',HEAD:'#06b6d4'};

const exportToExcel = () => {
    if (!data) return;
    const wb = XLSX.utils.book_new();
    const R = (val) => val ? parseFloat(val.toFixed(2)) : 0;
    const K = (val) => val ? Math.round(val) : 0;
    const dateLabel = viewType === "monthly" ? `${calendarMonth.split("-")[0]}년 ${selectedMonth}월` : selectedDate;
    const costLabel = viewType === "monthly" ? "월별 총 비용" : "일일 총 비용";
    const unalloc = data.unallocated_cost || 0;

    // 헤더 파란 배경 + 자동필터 적용 헬퍼
    const styleSheet = (ws, colCount) => {
      const hdr = { font: { bold: true, color: { rgb: "FFFFFF" } }, fill: { fgColor: { rgb: "4472C4" } }, alignment: { horizontal: "center" } };
      for (let i = 0; i < colCount; i++) {
        const addr = XLSX.utils.encode_cell({ r: 0, c: i });
        if (ws[addr]) ws[addr].s = hdr;
      }
      ws['!autofilter'] = { ref: XLSX.utils.encode_range({ s: { r: 0, c: 0 }, e: { r: 0, c: colCount - 1 } }) };
    };

    // 1. 요약
    const s1 = [
      ["비용 모니터링 리포트"], [""],
      ["기간", dateLabel],
      [costLabel + " (USD)", R(data.total_cost)],
      [costLabel + " (KRW)", K(data.total_cost * 1440)],
      ["배분 비용 (USD)", R(data.total_cost - unalloc)],
      ["미배분 비용 (USD)", R(unalloc)],
      ["미배분 비율", R(unalloc / data.total_cost * 100) + "%"],
      [""], ["프로젝트 수", projects.length],
      ["사용자 수", users.length],
      ["인스턴스 수", instances.length],
      [""],
      ["[비용 산출 기준]"],
      ["데이터 소스", "AWS CUR (Cost and Usage Report) + Enhanced Agent"],
      ["비용 기준", "RI/SP 할인 적용 후 인스턴스별 실제 비용 (effective cost)"],
      ["계정 레벨 할인", "EDP 3% 할인은 별도 적용됩니다"],
      [""],
      ["[모니터링 범위]"],
      ["대상 인스턴스", "GPU/HPC 인스턴스 6대 + ParallelCluster 컴퓨트 노드"],
      ["제외 인스턴스", "소형 운영 인스턴스 (t3 등)"],
      ["SP 비용 반영", "Savings Plan 월정액은 AWS 청구서에서 ComputeSavingsPlans 항목으로 별도 표기되며, 본 리포트에는 인스턴스별 실제 배분 비용(SP effective cost)으로 반영"],
      [""],
      ["[AWS 청구서 대조]"],
      ["AWS 청구서 AmazonEC2", "RI Fee + 온디맨드 비용 (SP는 상쇄 처리되어 $0)"],
      ["AWS 청구서 ComputeSavingsPlans", "SP 월정액 (EC2와 별도 항목)"],
      ["역산 검증", "AmazonEC2 + ComputeSavingsPlans - 제외 인스턴스(t3 등) ≈ 본 리포트 총비용"]
    ];
    XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(s1), "요약");

    // 2. 프로젝트별
    const s2 = [["프로젝트 코드", "설명", "GPU 비용 (USD)", "CPU 비용 (USD)", "합계 (USD)", "합계 (KRW)", "사용자"]];
    projects.forEach(p => {
      s2.push([p.code, p.description || "", R(p.gpu_cost), R(p.cpu_cost), R(p.cost_usd), K(p.cost_krw), (p.users||[]).join(", ")]);
      Object.entries(p.compute_nodes || {}).forEach(([t, cn]) => {
        s2.push(["  └ " + t + " (ParallelCluster)", "", "", R(cn.cost_usd), R(cn.cost_usd), K(cn.cost_krw), ""]);
      });
    });
    s2.push([]);
    s2.push(["미배분(미사용 시간 고정비)", "24/7 가동 인스턴스의 미사용 시간대 RI/SP 고정비", "", "", R(unalloc), K(unalloc * 1440), ""]);
    s2.push([]);
    s2.push(["합계", "", "", "", R(data.total_cost), K(data.total_cost * 1440), ""]);
    const ws2 = XLSX.utils.aoa_to_sheet(s2);
    styleSheet(ws2, 7);
    XLSX.utils.book_append_sheet(wb, ws2, "프로젝트별");

    // 3. 사용자별
    const s3 = [["사용자", "GPU 비용 (USD)", "CPU 비용 (USD)", "합계 (USD)", "합계 (KRW)", "프로젝트"]];
    users.forEach(u => s3.push([u.name, R(u.gpu_cost), R(u.cpu_cost), R(u.cost_usd), K(u.cost_krw), (u.projects||[]).join(", ")]));
    s3.push([]);
    s3.push(["미배분(미사용 시간 고정비)", "", "", R(unalloc), K(unalloc * 1440), ""]);
    s3.push([]);
    s3.push(["합계", "", "", R(data.total_cost), K(data.total_cost * 1440), ""]);
    const ws3 = XLSX.utils.aoa_to_sheet(s3);
    styleSheet(ws3, 6);
    XLSX.utils.book_append_sheet(wb, ws3, "사용자별");

    // 4. 인스턴스별
    const s4 = [["인스턴스 이름", "인스턴스 타입", "실제 비용 (USD)", "실제 비용 (KRW)", "가격 유형", "온디맨드 가격 (USD)", "할인율 (%)", "절감액 (USD)", "절감액 (KRW)", "할당 프로젝트"]];
    instances.forEach(([id, inst]) => {
      const pt = inst.pricing_type === 'RI' ? 'Reserved Instance' : inst.pricing_type === 'SP' ? 'Savings Plan' : '온디맨드';
      s4.push([inst.name || id, inst.type || id, R(inst.total_cost_usd), K(inst.total_cost_krw), pt, R(inst.ondemand_cost_usd || 0), R(inst.discount_pct || 0), R(inst.savings_usd || 0), K((inst.savings_usd || 0) * 1440), (inst.projects||[]).join(", ") || "미할당"]);
    });
    Object.entries(data.compute_nodes || {}).forEach(([type, cn]) => {
      s4.push([type + " (ParallelCluster)", type, R(cn.cost_usd), K(cn.cost_krw), "온디맨드", R(cn.cost_usd), 0, 0, 0, (cn.projects||[]).join(", ")]);
    });
    const totalSavings = instances.reduce((s, [,inst]) => s + (inst.savings_usd || 0), 0);
    const totalOD = instances.reduce((s, [,inst]) => s + (inst.ondemand_cost_usd || 0), 0);
    s4.push([]);
    s4.push(["합계", "", R(data.total_cost), K(data.total_cost * 1440), "", R(totalOD), totalOD > 0 ? R((1-data.total_cost/totalOD)*100) : 0, R(totalSavings), K(totalSavings * 1440), ""]);
    const ws4 = XLSX.utils.aoa_to_sheet(s4);
    styleSheet(ws4, 10);
    XLSX.utils.book_append_sheet(wb, ws4, "인스턴스별");

    // 5. 원본데이터 (Agent 상세 통합)
    const s5 = [["섹션", "항목", "코드/이름", "GPU 비용", "CPU 비용", "합계 (USD)", "합계 (KRW)", "상세", "명령어", "샘플 수", "GPU 디바이스", "평균 CPU%", "평균 GPU메모리(MB)", "가중치"]];
    s5.push(["기본정보", "기간", dateLabel, "", "", "", "", "", "", "", "", "", "", ""]);
    s5.push(["기본정보", "총비용", "", "", "", R(data.total_cost), K(data.total_cost * 1440), "", "", "", "", "", "", ""]);
    s5.push(["기본정보", "미배분", "", "", "", R(unalloc), K(unalloc * 1440), "", "", "", "", "", "", ""]);
    s5.push([]);
    (data.projects || []).forEach(p => {
      s5.push(["프로젝트", p.code, p.description || "", R(p.gpu_cost), R(p.cpu_cost), R(p.total_cost), K(p.total_cost*1440), "사용자: " + (p.users||[]).join(", "), "", "", "", "", "", ""]);
    });
    s5.push([]);
    (data.users || []).forEach(u => {
      s5.push(["사용자", u.username, "", R(u.gpu_cost), R(u.cpu_cost), R(u.total_cost), K(u.total_cost*1440), "프로젝트: " + (u.projects||[]).join(", "), "", "", "", "", "", ""]);
    });
    s5.push([]);
    Object.entries(data.instances || {}).forEach(([id, v]) => {
      s5.push(["인스턴스", v.name || id, v.type || "", R(v.gpu_cost), R(v.cpu_cost), R(v.total_cost_usd), K(v.total_cost_krw), "가격유형: " + (v.pricing_type||"OD") + " | 온디맨드: $" + R(v.ondemand_cost_usd||0) + " | 할인: " + R(v.discount_pct||0) + "%", "", "", "", "", "", ""]);
    });
    s5.push([]);
    if (data.validation) {
      Object.entries(data.validation).forEach(([k, v]) => s5.push(["검증", k, "", "", "", v, "", "", "", "", "", "", "", ""]));
    }
    s5.push([]);
    (data.agent_raw || []).forEach(r => {
      s5.push(["Agent", r.instance, r.project + " / " + r.user, "", "", "", "", "", r.command, r.samples, r.gpu_devices || "", r.avg_cpu_pct, r.avg_gpu_mem_mb, r.weight]);
    });
    const ws5 = XLSX.utils.aoa_to_sheet(s5);
    styleSheet(ws5, 14);
    XLSX.utils.book_append_sheet(wb, ws5, "원본데이터");

    XLSX.writeFile(wb, `cost_monitoring_${dateLabel.replace(/[년월\s]/g, "_")}.xlsx`);
  };

  const generateCalendar = () => {
    const [year, month] = calendarMonth.split('-').map(Number);
    const firstDay = new Date(year, month - 1, 1).getDay();
    const lastDate = new Date(year, month, 0).getDate();
    const minDate = new Date('2026-01-24');
    
    // KST 기준 오늘 날짜
    const kstToday = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Seoul' }));
    kstToday.setHours(0, 0, 0, 0);
    
    // 48시간 딜레이 적용
    const maxDate = new Date(kstToday.getTime() - 48 * 60 * 60 * 1000);
    
    const days = [];
    for (let i = 0; i < firstDay; i++) days.push(null);
    for (let d = 1; d <= lastDate; d++) {
      const date = new Date(year, month - 1, d);
      date.setHours(0, 0, 0, 0);
      const dateStr = `${year}-${String(month).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
      days.push({ date: dateStr, day: d, disabled: date < minDate || date > maxDate });
    }
    return days;
  };

  const projects = (data?.projects || []).filter(p => p.cost_usd > 1.0);
  const users = (data?.users || []).filter(u => u.cost_usd > 1.0);
  const instances = Object.entries(data?.instances || {}).sort((a,b) => b[1].total_cost_usd - a[1].total_cost_usd);

  // 프로젝트의 총 CPU/GPU 계산
  const getProjectResources = (p) => {
    let totalCpu = 0, totalGpu = 0;
    if (p.instance_details) {
      Object.values(p.instance_details).forEach(d => {
        if (d.cpu) totalCpu += d.cpu.cores_used || 0;
        if (d.gpu) totalGpu += d.gpu.avg_count || 0;
      });
    }
    return { cpu: totalCpu.toFixed(1), gpu: totalGpu.toFixed(1) };
  };


  const PieChart = React.memo(({ items, title, nameKey = 'name', totalOverride }) => {
    const [pieHovered, setPieHovered] = useState(null);
    if (!items?.length) return <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100"><h3 className="text-lg font-semibold text-gray-800 mb-4">{title}</h3><p className="text-gray-400 text-center py-8">데이터 없음</p></div>;
    const itemsTotal = items.reduce((s, i) => s + (i.cost_usd || 0), 0);
    const total = totalOverride || itemsTotal;
    const totalKrw = totalOverride ? totalOverride * 1440 : items.reduce((s, i) => s + (i.cost_krw || 0), 0);
    
    const paths = useMemo(() => {
      let angle = 0;
      return items.map((item, i) => {
        const pct = total > 0 ? (item.cost_usd || 0) / total : 0, a = pct * 360;
        const r1 = angle * Math.PI / 180, r2 = (angle + a) * Math.PI / 180;
        const innerR = 50, outerR = 85;
        const gap = 1.5;
        const r1g = (angle + gap) * Math.PI / 180, r2g = (angle + a - gap) * Math.PI / 180;
        const x1o = 100 + outerR * Math.cos(r1g), y1o = 100 + outerR * Math.sin(r1g);
        const x2o = 100 + outerR * Math.cos(r2g), y2o = 100 + outerR * Math.sin(r2g);
        const x1i = 100 + innerR * Math.cos(r1g), y1i = 100 + innerR * Math.sin(r1g);
        const x2i = 100 + innerR * Math.cos(r2g), y2i = 100 + innerR * Math.sin(r2g);
        
        const outerRHover = 90;
        const x1oh = 100 + outerRHover * Math.cos(r1g), y1oh = 100 + outerRHover * Math.sin(r1g);
        const x2oh = 100 + outerRHover * Math.cos(r2g), y2oh = 100 + outerRHover * Math.sin(r2g);
        const x1ih = 100 + innerR * Math.cos(r1g), y1ih = 100 + innerR * Math.sin(r1g);
        const x2ih = 100 + innerR * Math.cos(r2g), y2ih = 100 + innerR * Math.sin(r2g);
        
        const pathD = `M${x1o} ${y1o}A${outerR} ${outerR} 0 ${a > 180 ? 1 : 0} 1 ${x2o} ${y2o}L${x2i} ${y2i}A${innerR} ${innerR} 0 ${a > 180 ? 1 : 0} 0 ${x1i} ${y1i}Z`;
        const pathDHover = `M${x1oh} ${y1oh}A${outerRHover} ${outerRHover} 0 ${a > 180 ? 1 : 0} 1 ${x2oh} ${y2oh}L${x2ih} ${y2ih}A${innerR} ${innerR} 0 ${a > 180 ? 1 : 0} 0 ${x1ih} ${y1ih}Z`;
        angle += a;
        return { pathD, pathDHover, color: colors[i % colors.length], index: i };
      });
    }, [items, total]);

    return (
      <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <h3 className="text-lg font-semibold text-gray-800 mb-4">{title}</h3>
        <div className="flex items-start gap-6">
          <div key={title + items.length} className="relative flex-shrink-0" style={{overflow: 'visible', }}>
            <svg width="300" height="300" viewBox="0 0 200 200" className="transform -rotate-90" style={{overflow: 'visible'}}>
              {paths.map(p => (
                <path key={p.index} d={hovered === p.index ? p.pathDHover : p.pathD} fill={p.color} opacity={pieHovered === null || pieHovered === p.index ? 1 : 0.5} style={{cursor: 'pointer', transition: 'all 0.2s', transformOrigin: '100px 100px'}} onMouseEnter={() => setPieHovered(p.index)} onMouseLeave={() => setPieHovered(null)} />
              ))}
            </svg>
            <style></style>
            <div className="absolute inset-0 flex items-center justify-center">
              {pieHovered !== null ? (
                <div className="text-center">
                  <p className="text-2xl font-bold text-gray-800">{((items[pieHovered]?.cost_usd / total) * 100).toFixed(1)}%</p>
                  <p className="text-xs text-gray-500 mt-1 max-w-[120px] truncate">{items[pieHovered]?.[nameKey] || items[pieHovered]?.code}</p>
                </div>
              ) : (
                <div className="text-center">
                  <p className="text-xs text-gray-400 font-semibold mb-1">TOTAL</p>
                  <p className="text-lg font-bold text-gray-800">{fmt(total, totalKrw)}</p>
                </div>
              )}
            </div>
          </div>
          <div className="flex-1 space-y-0.5 text-sm">
            {items.map((item, i) => (
              <div key={i} onMouseEnter={() => setPieHovered(i)} onMouseLeave={() => setPieHovered(null)} className={"flex items-center gap-1 p-0.5 rounded transition-colors " + (pieHovered === i ? "bg-indigo-50" : "")}>
                <div className="w-2 h-2 rounded-full flex-shrink-0" style={{background: colors[i % 10]}}></div>
                <div className="flex-1 truncate">
                  <span className="text-gray-900 font-medium">{item.code || item[nameKey]}</span>
                  {item.description && <span className="text-gray-500 text-xs ml-0">({item.description})</span>}
                </div>
                <span className="font-semibold text-indigo-600">{fmt(item.cost_usd, item.cost_krw)}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    );
  });

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
      <div className="max-w-[1600px] mx-auto px-4 py-6">
        <div className="mb-6">
          <div className="flex items-center gap-3">
            <h1 className="text-2xl font-bold text-gray-900">비용 모니터링</h1>
            <button onClick={() => { setShowSettings(true); fetch('/api/cost-monitoring/mappings').then(r=>r.json()).then(d=>{setMappings(d);setEditingMappings(JSON.parse(JSON.stringify(d)));}); }} className="p-1.5 rounded-lg hover:bg-gray-200 text-gray-400 hover:text-gray-600 transition-all" title="매핑 설정">
