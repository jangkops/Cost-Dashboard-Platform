import React, { useState, useEffect } from "react";

export default function CostMonitoring() {
  const [currency, setCurrency] = useState('KRW');
  const [selectedDate, setSelectedDate] = useState(new Date().toISOString().split('T')[0]);
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(false);
  const [viewMode, setViewMode] = useState('project');
  const [calendarMonth, setCalendarMonth] = useState(new Date().toISOString().slice(0,7));

  useEffect(() => { loadData(); }, [selectedDate]);

  const loadData = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/cost-monitoring/finops/daily-cost-allocation/' + selectedDate);
      if (res.ok) {
        const result = await res.json();
        console.log('API Response:', result);
        setData(result);
      } else {
        console.error('API Error:', res.status);
        setData(null);
      }
    } catch (e) { 
      console.error('Load Error:', e);
      setData(null);
    }
    setLoading(false);
  };

  const fmt = (usd, krw) => {
    if (currency === 'KRW') return krw ? '₩' + krw.toLocaleString() : '₩0';
    return usd ? '$' + usd.toFixed(2) : '$0.00';
  };

  const colors = ['#6366f1','#8b5cf6','#ec4899','#f43f5e','#f97316','#eab308','#22c55e','#14b8a6','#06b6d4','#3b82f6'];
  const instColors = {G5:'#6366f1',R7:'#22c55e',P4D:'#f43f5e',P4DE:'#8b5cf6',HEAD:'#06b6d4'};

  const generateCalendar = () => {
    const [year, month] = calendarMonth.split('-').map(Number);
    const firstDay = new Date(year, month - 1, 1).getDay();
    const lastDate = new Date(year, month, 0).getDate();
    const minDate = new Date('2025-12-24');
    const today = new Date();
    const maxDate = new Date(today.getTime() - 48 * 60 * 60 * 1000); // 48시간 전
    const days = [];
    for (let i = 0; i < firstDay; i++) days.push(null);
    for (let d = 1; d <= lastDate; d++) {
      const date = new Date(year, month - 1, d);
      const dateStr = date.toISOString().split('T')[0];
      days.push({ date: dateStr, day: d, disabled: date < minDate || date > maxDate });
    }
    return days;
  };

  const projects = (data?.projects || []).filter(p => p.total_cost > 0.01);
  const users = (data?.users || []).filter(u => u.total_cost > 0.01);
  const instances = [];

  // 프로젝트의 총 CPU/GPU 계산
  const getProjectResources = (p) => {
    let totalCpu = 0, totalGpu = 0;
    if (p.instance_details) {
      Object.values(p.instance_details).forEach(d => {
        if (d.cpu) totalCpu += d.cpu.cores_used || 0;
        if (d.gpu) totalGpu += d.gpu.avg_count || 0;
      });
    }
    return { cpu: totalCpu.toFixed(1), gpu: totalGpu.toFixed(1) };
  };

  const PieChart = ({ items, title, nameKey = 'name' }) => {
    if (!items?.length) return <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100"><h3 className="text-lg font-semibold text-gray-800 mb-4">{title}</h3><p className="text-gray-400 text-center py-8">데이터 없음</p></div>;
    const total = items.reduce((s, i) => s + (i.total_cost || 0), 0);
    const totalKrw = items.reduce((s, i) => s + ((i.total_cost || 0) * 1380), 0);
    let angle = 0;
    return (
      <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <h3 className="text-lg font-semibold text-gray-800 mb-4">{title}</h3>
        <div className="flex items-start gap-6">
          <div className="relative flex-shrink-0">
            <svg width="140" height="140" viewBox="0 0 200 200" className="transform -rotate-90">
              {items.slice(0, 10).map((item, i) => {
                const pct = (item.cost_usd || 0) / total, a = pct * 360;
                const r1 = angle * Math.PI / 180, r2 = (angle + a) * Math.PI / 180;
                const x1 = 100 + 85 * Math.cos(r1), y1 = 100 + 85 * Math.sin(r1);
                const x2 = 100 + 85 * Math.cos(r2), y2 = 100 + 85 * Math.sin(r2);
                angle += a;
                return <path key={i} d={'M100 100L' + x1 + ' ' + y1 + 'A85 85 0 ' + (a > 180 ? 1 : 0) + ' 1 ' + x2 + ' ' + y2 + 'Z'} fill={colors[i % 10]} />;
              })}
            </svg>
            <div className="absolute inset-0 flex items-center justify-center"><p className="text-lg font-bold text-gray-800">{fmt(total, totalKrw)}</p></div>
          </div>
          <div className="flex-1 space-y-1.5 max-h-36 overflow-y-auto text-sm">
            {items.slice(0, 10).map((item, i) => (
              <div key={i} className="flex items-center gap-2">
                <div className="w-2 h-2 rounded-full flex-shrink-0" style={{background: colors[i % 10]}}></div>
                <span className="flex-1 truncate text-gray-700">{item[nameKey] || item.code}</span>
                <span className="font-semibold text-indigo-600">{fmt(item.cost_usd, item.total_cost * 1380)}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    );
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
      <div className="max-w-7xl mx-auto px-4 py-6">
        <div className="mb-6">
          <h1 className="text-2xl font-bold text-gray-900">비용 모니터링</h1>
          <p className="text-sm text-gray-500">{data?.data_source || ''} | {data?.agent_version || ''}</p>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-4 gap-6">
          <div className="lg:col-span-1">
            <div className="bg-white rounded-2xl p-4 shadow-sm border border-gray-100 sticky top-4">
              <div className="flex items-center justify-between mb-3">
                <button onClick={() => { const [y,m] = calendarMonth.split('-'); setCalendarMonth(m==='01' ? (y-1)+'-12' : y+'-'+(m-1).toString().padStart(2,'0')); }} className="p-1 hover:bg-gray-100 rounded">◀</button>
                <span className="font-semibold text-gray-800">{calendarMonth}</span>
                <button onClick={() => { const [y,m] = calendarMonth.split('-'); setCalendarMonth(m==='12' ? (Number(y)+1)+'-01' : y+'-'+(Number(m)+1).toString().padStart(2,'0')); }} className="p-1 hover:bg-gray-100 rounded">▶</button>
              </div>
              <div className="grid grid-cols-7 gap-1 text-xs text-center mb-2">
                {['일','월','화','수','목','금','토'].map(d => <div key={d} className="text-gray-400 py-1">{d}</div>)}
              </div>
              <div className="grid grid-cols-7 gap-1">
                {generateCalendar().map((d, i) => d ? (
                  <button key={i} onClick={() => !d.disabled && setSelectedDate(d.date)} disabled={d.disabled}
                    className={'p-2 text-sm rounded-lg transition-all ' + (d.disabled ? 'text-gray-300 cursor-not-allowed' : selectedDate === d.date ? 'bg-indigo-600 text-white' : 'hover:bg-gray-100 text-gray-700')}>
                    {d.day}
                  </button>
                ) : <div key={i}></div>)}
              </div>
              <div className="mt-4 pt-4 border-t border-gray-100">
                <p className="text-xs text-gray-500 mb-2">통화</p>
                <div className="flex gap-1">
                  {['USD','KRW'].map(c => (
                    <button key={c} onClick={() => setCurrency(c)} className={'flex-1 py-1.5 text-xs rounded-lg transition-all ' + (currency === c ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200')}>{c}</button>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <div className="lg:col-span-3">
            {loading ? (
              <div className="flex items-center justify-center py-20"><div className="w-8 h-8 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin"></div></div>
            ) : data ? (
              <>
                <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
                  <div className="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-500">일일 총 비용</p>
                    <p className="text-xl font-bold text-indigo-600">{fmt(data.summary.total_cost, data.summary.total_cost * 1380)}</p>
                    <p className="text-xs text-gray-400">{selectedDate}</p>
                  </div>
                  <div className="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-500">월 예상 (30일)</p>
                    <p className="text-xl font-bold text-gray-900">{fmt((data.summary.total_cost||0)*30, (data.summary.total_cost * 1380||0)*30)}</p>
                  </div>
                  <div className="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-500">프로젝트</p>
                    <p className="text-xl font-bold text-gray-900">{projects.length}개</p>
                  </div>
                  <div className="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-500">사용자</p>
                    <p className="text-xl font-bold text-gray-900">{users.length}명</p>
                  </div>
                </div>

                <div className="flex gap-2 mb-4">
                  {['project','user','instance'].map(m => (
                    <button key={m} onClick={() => setViewMode(m)} className={'px-4 py-2 text-sm rounded-lg ' + (viewMode === m ? 'bg-indigo-600 text-white' : 'bg-white text-gray-600 border border-gray-200')}>
                      {m === 'project' ? '프로젝트별' : m === 'user' ? '사용자별' : '인스턴스별'}
                    </button>
                  ))}
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                  {viewMode === 'project' && <PieChart items={projects} title="프로젝트별 비용" nameKey="code" />}
                  {viewMode === 'user' && <PieChart items={users} title="사용자별 비용" nameKey="name" />}
                  {viewMode === 'instance' && (
                    <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                      <h3 className="text-lg font-semibold text-gray-800 mb-4">인스턴스별 비용</h3>
                      <div className="space-y-3">
                        {instances.map(([name, v]) => (
                          <div key={name}>
                            <div className="flex justify-between text-sm mb-1">
                              <span className="font-medium text-gray-700">{name} <span className="text-xs text-gray-400">({v.type})</span></span>
                              <span className="font-semibold text-indigo-600">{fmt(v.total_cost_usd, v.total_cost_krw)}</span>
                            </div>
                            <div className="h-2 bg-gray-100 rounded-full overflow-hidden">
                              <div className="h-full rounded-full" style={{width: (v.total_cost_usd/(instances[0]?.[1]?.total_cost_usd||1))*100 + '%', background: instColors[name] || '#6366f1'}}></div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                  <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                    <h3 className="text-lg font-semibold text-gray-800 mb-4">인스턴스 현황</h3>
                    <div className="space-y-2 text-sm">
                      {instances.map(([name, v]) => (
                        <div key={name} className="flex justify-between items-center py-2 border-b border-gray-50">
                          <div>
                            <span className="font-medium" style={{color: instColors[name]}}>{name}</span>
                            <span className="text-xs text-gray-400 ml-2">{v.type}</span>
                          </div>
                          <div className="text-right text-xs text-gray-500">
                            <span className="mr-3">CPU {v.cpu_cores}코어</span>
                            <span>GPU {v.gpu_count}개</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>

                <div className="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                  <div className="px-4 py-3 border-b border-gray-100">
                    <h3 className="font-semibold text-gray-800">{viewMode === 'project' ? '프로젝트 상세' : viewMode === 'user' ? '사용자 상세' : '인스턴스 상세'}</h3>
                  </div>
                  <div className="overflow-x-auto">
                    <table className="w-full text-sm">
                      <thead className="bg-gray-50">
                        <tr>
                          <th className="px-4 py-2 text-left text-xs font-semibold text-gray-500">{viewMode === 'project' ? '프로젝트' : viewMode === 'user' ? '사용자' : '인스턴스'}</th>
                          <th className="px-4 py-2 text-right text-xs font-semibold text-gray-500">비용</th>
                          <th className="px-4 py-2 text-right text-xs font-semibold text-gray-500">CPU 사용</th>
                          <th className="px-4 py-2 text-right text-xs font-semibold text-gray-500">GPU 사용</th>
                          <th className="px-4 py-2 text-right text-xs font-semibold text-gray-500">{viewMode === 'instance' ? '프로젝트 수' : '사용자/인스턴스'}</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-gray-100">
                        {viewMode === 'project' && projects.map((p, i) => {
                          const res = getProjectResources(p);
                          return (
                            <tr key={i} className="hover:bg-gray-50">
                              <td className="px-4 py-3">
                                <p className="font-medium text-gray-900">{p.code}</p>
                                <p className="text-xs text-gray-500">{p.name !== p.code ? p.name : ''}</p>
                              </td>
                              <td className="px-4 py-3 text-right font-semibold text-indigo-600">{fmt(p.total_cost)}</td>
                              <td className="px-4 py-3 text-right text-gray-600">{res.cpu} 코어</td>
                              <td className="px-4 py-3 text-right text-gray-600">{res.gpu > 0 ? res.gpu + ' GPU' : '-'}</td>
                              <td className="px-4 py-3 text-right text-gray-500 text-xs">{(p.users||[]).join(', ')}</td>
                            </tr>
                          );
                        })}
                        {viewMode === 'user' && users.map((u, i) => (
                          <tr key={i} className="hover:bg-gray-50">
                            <td className="px-4 py-3 font-medium text-gray-900">{u.name}</td>
                            <td className="px-4 py-3 text-right font-semibold text-indigo-600">{fmt(u.total_cost)}</td>
                            <td className="px-4 py-3 text-right text-gray-600">-</td>
                            <td className="px-4 py-3 text-right text-gray-600">-</td>
                            <td className="px-4 py-3 text-right text-gray-500 text-xs">{(u.projects||[]).slice(0,3).join(', ')}</td>
                          </tr>
                        ))}
                        {viewMode === 'instance' && instances.map(([name, v], i) => (
                          <tr key={i} className="hover:bg-gray-50">
                            <td className="px-4 py-3">
                              <p className="font-medium text-gray-900">{name}</p>
                              <p className="text-xs text-gray-500">{v.type}</p>
                            </td>
                            <td className="px-4 py-3 text-right font-semibold text-indigo-600">{fmt(v.total_cost_usd, v.total_cost_krw)}</td>
                            <td className="px-4 py-3 text-right text-gray-600">{v.cpu_cores} 코어</td>
                            <td className="px-4 py-3 text-right text-gray-600">{v.gpu_count} GPU</td>
                            <td className="px-4 py-3 text-right text-gray-500">{(v.projects||[]).length}개</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>

                {data.cost_note && (
                  <div className="mt-4 p-3 bg-blue-50 rounded-lg text-sm text-blue-700">ℹ️ {data.cost_note}</div>
                )}
              </>
            ) : <div className="text-center py-20 text-gray-400">날짜를 선택하세요</div>}
          </div>
        </div>
      </div>
    </div>
  );
}
