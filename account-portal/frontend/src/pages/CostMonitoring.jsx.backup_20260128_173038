import React, { useState, useEffect } from "react";

export default function CostMonitoring() {
  const [currency, setCurrency] = useState('USD');
  const [activeTab, setActiveTab] = useState('projects');
  const [hoveredItem, setHoveredItem] = useState(null);
  const [selectedDate, setSelectedDate] = useState(() => {
    const d = new Date();
    d.setDate(d.getDate() - 2);
    return d.toISOString().split('T')[0];
  });
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(false);
  const [calendarMonth, setCalendarMonth] = useState(new Date().toISOString().slice(0,7));

  useEffect(() => { loadData(); }, [selectedDate]);

  const loadData = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/finops/daily/' + selectedDate);
      if (res.ok) {
        const result = await res.json();
        if (result.success) {
          setData(result);
        }
      } else {
        setData(null);
      }
    } catch (e) { 
      setData(null);
    }
    setLoading(false);
  };

  const fmt = (usd) => {
    if (currency === 'KRW') return '₩' + (usd * 1380).toLocaleString(undefined, {maximumFractionDigits: 0});
    return '$' + usd.toFixed(2);
  };

  const colors = ['#6366f1','#8b5cf6','#ec4899','#f43f5e','#f97316','#eab308','#22c55e','#14b8a6','#06b6d4','#3b82f6'];

  const generateCalendar = () => {
    const [year, month] = calendarMonth.split('-').map(Number);
    const firstDay = new Date(year, month - 1, 1).getDay();
    const lastDate = new Date(year, month, 0).getDate();
    const minDate = new Date('2026-01-01');
    const maxDate = new Date();
    maxDate.setDate(maxDate.getDate() - 2);
    
    const days = [];
    for (let i = 0; i < firstDay; i++) days.push(null);
    for (let d = 1; d <= lastDate; d++) {
      const date = new Date(year, month - 1, d);
      const dateStr = date.toISOString().split('T')[0];
      days.push({ date: dateStr, day: d, disabled: date < minDate || date > maxDate });
    }
    return days;
  };

  const projects = Object.entries(data?.project_costs || {})
    .map(([name, cost]) => ({name, ...cost}))
    .filter(p => p.total_cost > 0.01)
    .sort((a,b) => b.total_cost - a.total_cost);

  const users = Object.entries(data?.user_costs || {})
    .map(([name, cost]) => ({name, ...cost}))
    .filter(u => u.total_cost > 0.01)
    .sort((a,b) => b.total_cost - a.total_cost);

  const instances = Object.entries(data?.instance_costs || {})
    .map(([name, cost]) => ({name, ...cost}))
    .filter(i => i.total_cost > 0.01)
    .sort((a,b) => b.total_cost - a.total_cost);

  const PieChart = ({ items, title }) => {
    if (!items?.length) return <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100"><h3 className="text-lg font-semibold text-gray-800 mb-4">{title}</h3><p className="text-gray-400 text-center py-8">데이터 없음</p></div>;
    const total = items.reduce((s, i) => s + (i.total_cost || 0), 0);
    let angle = 0;
    return (
      <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <h3 className="text-lg font-semibold text-gray-800 mb-4">{title}</h3>
        <div className="flex items-start gap-6">
          <div className="relative flex-shrink-0">
            <svg width="200" height="200" viewBox="0 0 200 200" className="transform -rotate-90">
              {items.slice(0, 10).map((item, i) => {
                const pct = (item.total_cost || 0) / total;
                const a = pct * 360;
                const r1 = angle * Math.PI / 180, r2 = (angle + a) * Math.PI / 180;
                const x1 = 100 + 85 * Math.cos(r1), y1 = 100 + 85 * Math.sin(r1);
                const x2 = 100 + 85 * Math.cos(r2), y2 = 100 + 85 * Math.sin(r2);
                const currentAngle = angle;
                angle += a;
                return (
                  <path 
                    key={i} 
                    d={'M100 100L' + x1 + ' ' + y1 + 'A85 85 0 ' + (a > 180 ? 1 : 0) + ' 1 ' + x2 + ' ' + y2 + 'Z'} 
                    fill={colors[i % 10]}
                    opacity={hoveredItem === i ? 1 : 0.85}
                    onMouseEnter={() => setHoveredItem(i)}
                    onMouseLeave={() => setHoveredItem(null)}
                    className="cursor-pointer transition-opacity"
                  />
                );
              })}
            </svg>
            <div className="absolute inset-0 flex items-center justify-center flex-col">
              {hoveredItem !== null ? (
                <>
                  <p className="text-2xl font-bold text-gray-800">{((items[hoveredItem].total_cost / total) * 100).toFixed(1)}%</p>
                  <p className="text-xs text-gray-500 mt-1">{items[hoveredItem].name}</p>
                </>
              ) : (
                <p className="text-xl font-bold text-gray-800">{fmt(total)}</p>
              )}
            </div>
          </div>
          <div className="flex-1 space-y-2 max-h-80 overflow-y-auto text-sm">
            {items.slice(0, 10).map((item, i) => (
              <div 
                key={i} 
                className="flex items-center gap-2 p-2 rounded hover:bg-gray-50 cursor-pointer transition-colors"
                onMouseEnter={() => setHoveredItem(i)}
                onMouseLeave={() => setHoveredItem(null)}
              >
                <div className="w-3 h-3 rounded-full flex-shrink-0" style={{background: colors[i % 10]}}></div>
                <span className="flex-1 truncate text-gray-700">{item.name}</span>
                <span className="font-semibold text-indigo-600">{fmt(item.total_cost)}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    );
  };

  const currentItems = activeTab === 'projects' ? projects : activeTab === 'users' ? users : instances;
  const chartTitle = activeTab === 'projects' ? '프로젝트별 일일 비용' : activeTab === 'users' ? '사용자별 일일 비용' : '인스턴스별 일일 비용';
  const totalCost = data?.total_cost || 0;

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
      <div className="max-w-7xl mx-auto px-4 py-6">
        <div className="mb-6">
          <h1 className="text-2xl font-bold text-gray-900">일일 비용 모니터링</h1>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-4 gap-6">
          <div className="lg:col-span-1">
            <div className="bg-white rounded-2xl p-4 shadow-sm border border-gray-100 sticky top-4">
              <div className="flex items-center justify-between mb-3">
                <button onClick={() => { const [y,m] = calendarMonth.split('-'); setCalendarMonth(m==='01' ? (y-1)+'-12' : y+'-'+(m-1).toString().padStart(2,'0')); }} className="p-1 hover:bg-gray-100 rounded">◀</button>
                <span className="font-semibold text-gray-800">{calendarMonth}</span>
                <button onClick={() => { const [y,m] = calendarMonth.split('-'); setCalendarMonth(m==='12' ? (Number(y)+1)+'-01' : y+'-'+(Number(m)+1).toString().padStart(2,'0')); }} className="p-1 hover:bg-gray-100 rounded">▶</button>
              </div>
              <div className="grid grid-cols-7 gap-1 text-xs text-center mb-2">
                {['일','월','화','수','목','금','토'].map(d => <div key={d} className="text-gray-400 py-1">{d}</div>)}
              </div>
              <div className="grid grid-cols-7 gap-1">
                {generateCalendar().map((d, i) => d ? (
                  <button key={i} onClick={() => !d.disabled && setSelectedDate(d.date)} disabled={d.disabled}
                    className={'p-2 text-sm rounded-lg transition-all ' + (d.disabled ? 'text-gray-300 cursor-not-allowed' : selectedDate === d.date ? 'bg-indigo-600 text-white' : 'hover:bg-gray-100 text-gray-700')}>
                    {d.day}
                  </button>
                ) : <div key={i}></div>)}
              </div>
              <div className="mt-4 pt-4 border-t border-gray-100">
                <p className="text-xs text-gray-500 mb-2">통화</p>
                <div className="flex gap-1">
                  {['USD','KRW'].map(c => (
                    <button key={c} onClick={() => setCurrency(c)} className={'flex-1 py-1.5 text-xs rounded-lg transition-all ' + (currency === c ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200')}>{c}</button>
                  ))}
                </div>
              </div>
              <div className="mt-4 pt-4 border-t border-gray-100">
                <p className="text-xs text-amber-600">48시간 지연 정책</p>
                <p className="text-xs text-gray-500 mt-1">CUR 검증 완료된 데이터만 표시</p>
              </div>
            </div>
          </div>

          <div className="lg:col-span-3">
            {loading ? (
              <div className="flex items-center justify-center py-20"><div className="w-8 h-8 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin"></div></div>
            ) : data ? (
              <>
                <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
                  <div className="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-500">일일 총 비용</p>
                    <p className="text-xl font-bold text-indigo-600">{fmt(totalCost)}</p>
                    <p className="text-xs text-gray-400">{selectedDate}</p>
                  </div>
                  <div className="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-500">월 예상 (30일)</p>
                    <p className="text-xl font-bold text-gray-900">{fmt(totalCost * 30)}</p>
                  </div>
                  <div className="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-500">프로젝트</p>
                    <p className="text-xl font-bold text-gray-900">{data.projects_count}개</p>
                  </div>
                  <div className="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-500">총 GPU 시간</p>
                    <p className="text-xl font-bold text-gray-900">{projects.reduce((s,p) => s + p.gpu_hours, 0).toFixed(1)}h</p>
                  </div>
                </div>

                <div className="mb-4 flex gap-2">
                  <button onClick={() => setActiveTab('projects')} className={'px-6 py-2.5 text-sm font-medium rounded-lg transition-all ' + (activeTab === 'projects' ? 'bg-indigo-600 text-white shadow-md' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200')}>프로젝트별</button>
                  <button onClick={() => setActiveTab('users')} className={'px-6 py-2.5 text-sm font-medium rounded-lg transition-all ' + (activeTab === 'users' ? 'bg-indigo-600 text-white shadow-md' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200')}>사용자별</button>
                  <button onClick={() => setActiveTab('instances')} className={'px-6 py-2.5 text-sm font-medium rounded-lg transition-all ' + (activeTab === 'instances' ? 'bg-indigo-600 text-white shadow-md' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200')}>인스턴스별</button>
                </div>

                <PieChart items={currentItems} title={chartTitle} />

              </>
            ) : <div className="text-center py-20 text-gray-400">날짜를 선택하세요</div>}
          </div>
        </div>
      </div>
    </div>
  );
}
