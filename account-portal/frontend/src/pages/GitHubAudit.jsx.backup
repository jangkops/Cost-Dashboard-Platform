import { useState, useEffect } from "react";
import { motion } from "framer-motion";
import { ChevronRightIcon, ClockIcon, ArrowPathIcon, FunnelIcon } from "@heroicons/react/24/outline";

export default function GitHubAudit() {
  const [repos, setRepos] = useState([]);
  const [selectedRepo, setSelectedRepo] = useState(null);
  const [events, setEvents] = useState([]);
  const [filteredEvents, setFilteredEvents] = useState([]);
  const [loading, setLoading] = useState(true);
  const [eventsLoading, setEventsLoading] = useState(false);
  const [filterUser, setFilterUser] = useState("");
  const [filterType, setFilterType] = useState("all");
  const [days, setDays] = useState(30);
  const [auditLogs, setAuditLogs] = useState([]);
  const [auditLoading, setAuditLoading] = useState(false);

  useEffect(() => {
    loadRepos();
    loadAuditLogs();
  }, []);

  useEffect(() => {
    filterEvents();
  }, [events, filterUser, filterType]);

  const loadRepos = async () => {
    setLoading(true);
    try {
      const res = await fetch("/api/github/organizations/mogam-ai/repositories");
      const data = await res.json();
      setRepos(data || []);
      if (data && data.length > 0) {
        selectRepo(data[0]);
      }
    } catch (err) {
      console.error("Failed to load repos:", err);
    } finally {
      setLoading(false);
    }
  };

  const loadAuditLogs = async () => {
    setAuditLoading(true);
    try {
      const res = await fetch("/api/audit-logs");
      const data = await res.json();
      setAuditLogs(data.logs || []);
    } catch (err) {
      console.error("Failed to load audit logs:", err);
    } finally {
      setAuditLoading(false);
    }
  };

  const selectRepo = async (repo) => {
    setSelectedRepo(repo);
    setEventsLoading(true);
    try {
      const res = await fetch(`/api/github/repositories/${repo.owner.login}/${repo.name}/events?days=${days}`);
      const data = await res.json();
      setEvents(data || []);
    } catch (err) {
      console.error("Failed to load events:", err);
      setEvents([]);
    } finally {
      setEventsLoading(false);
    }
  };

  const filterEvents = () => {
    let filtered = events;
    
    if (filterUser) {
      filtered = filtered.filter(e => 
        e.actor.toLowerCase().includes(filterUser.toLowerCase())
      );
    }
    
    if (filterType !== "all") {
      filtered = filtered.filter(e => e.type === filterType);
    }
    
    setFilteredEvents(filtered);
  };

  const getEventDescription = (event) => {
    const payload = event.payload || {};
    switch(event.type) {
      case 'PushEvent':
        const commits = payload.commits?.length || 0;
        return commits > 0 ? `${commits}개 커밋 푸시` : '푸시';
      case 'PullRequestEvent':
        return `PR ${payload.action}: ${payload.pull_request?.title || ''}`;
      case 'PullRequestReviewEvent':
        return `PR 리뷰 ${payload.action}`;
      case 'IssuesEvent':
        return `이슈 ${payload.action}: ${payload.issue?.title || ''}`;
      case 'IssueCommentEvent':
        return `이슈 댓글 작성`;
      case 'CreateEvent':
        return `${payload.ref_type} 생성: ${payload.ref || ''}`;
      case 'DeleteEvent':
        return `${payload.ref_type} 삭제: ${payload.ref || ''}`;
      case 'WatchEvent':
        return `저장소 스타`;
      case 'ForkEvent':
        return `저장소 포크`;
      case 'ReleaseEvent':
        return `릴리즈 ${payload.action}: ${payload.release?.tag_name || ''}`;
      case 'MemberEvent':
        return `멤버 ${payload.action}: ${payload.member?.login || ''}`;
      default:
        return event.type.replace('Event', '');
    }
  };

  const eventTypes = [
    { value: 'all', label: '전체' },
    { value: 'PushEvent', label: 'Push' },
    { value: 'PullRequestEvent', label: 'Pull Request' },
    { value: 'PullRequestReviewEvent', label: 'PR Review' },
    { value: 'IssuesEvent', label: 'Issues' },
    { value: 'CreateEvent', label: 'Create' },
    { value: 'DeleteEvent', label: 'Delete' }
  ];

  const uniqueUsers = [...new Set(events.map(e => e.actor))].sort();

  return (
    <div className="min-h-screen bg-gradient-to-br from-purple-50 via-white to-pink-50 p-8">
      <motion.div initial={{opacity:0,y:-20}} animate={{opacity:1,y:0}} className="flex items-center gap-2 text-sm text-gray-600 mb-6">
        <span className="font-medium text-purple-600">GitHub 관리</span>
        <ChevronRightIcon className="w-4 h-4" />
        <span>감사 로그</span>
      </motion.div>

      <div className="max-w-[1400px] mx-auto">
        <div className="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
          <div className="flex items-center justify-between mb-8">
            <div className="flex items-center gap-4">
              <div className="p-3 bg-purple-100 rounded-xl">
                <ClockIcon className="w-8 h-8 text-purple-600" />
              </div>
              <div>
                <h1 className="text-3xl font-bold text-gray-900">GitHub 감사 로그</h1>
                <p className="text-gray-500 mt-1">사용자별 Git 활동 이력 (Push, Merge, PR 등)</p>
              </div>
            </div>
            <button 
              onClick={() => selectedRepo && selectRepo(selectedRepo)} 
              disabled={eventsLoading}
              className="flex items-center gap-2 px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 disabled:opacity-50"
            >
              <ArrowPathIcon className={`w-5 h-5 ${eventsLoading ? 'animate-spin' : ''}`} />
              새로고침
            </button>
          </div>

          {loading ? (
            <div className="text-center py-16">
              <div className="inline-block animate-spin rounded-full h-12 w-12 border-4 border-purple-200 border-t-purple-600"></div>
              <p className="mt-4 text-gray-500">로딩 중...</p>
            </div>
          ) : (
            <div className="space-y-6">
              {/* Repository Selection */}
              <div>
                <label className="block text-sm font-semibold text-gray-700 mb-3">저장소 선택</label>
                <select
                  value={selectedRepo?.id || ''}
                  onChange={(e) => {
                    const repo = repos.find(r => r.id === parseInt(e.target.value));
                    if (repo) selectRepo(repo);
                  }}
                  className="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500"
                >
                  {repos.map(repo => (
                    <option key={repo.id} value={repo.id}>
                      {repo.name} {repo.description ? `- ${repo.description}` : ''}
                    </option>
                  ))}
                </select>
              </div>

              {/* Filters */}
              <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                  <label className="block text-sm font-semibold text-gray-700 mb-2">사용자 필터</label>
                  <select
                    value={filterUser}
                    onChange={(e) => setFilterUser(e.target.value)}
                    className="w-full px-4 py-2 border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-purple-500"
                  >
                    <option value="">전체 사용자</option>
                    {uniqueUsers.map(user => (
                      <option key={user} value={user}>{user}</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label className="block text-sm font-semibold text-gray-700 mb-2">이벤트 타입</label>
                  <select
                    value={filterType}
                    onChange={(e) => setFilterType(e.target.value)}
                    className="w-full px-4 py-2 border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-purple-500"
                  >
                    {eventTypes.map(type => (
                      <option key={type.value} value={type.value}>{type.label}</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label className="block text-sm font-semibold text-gray-700 mb-2">기간</label>
                  <select
                    value={days}
                    onChange={(e) => {
                      setDays(parseInt(e.target.value));
                      if (selectedRepo) selectRepo(selectedRepo);
                    }}
                    className="w-full px-4 py-2 border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-purple-500"
                  >
                    <option value="7">최근 7일</option>
                    <option value="30">최근 30일</option>
                    <option value="90">최근 90일</option>
                  </select>
                </div>
              </div>

              {/* Events List */}
              <div>
                <div className="flex items-center justify-between mb-4">
                  <h2 className="text-lg font-semibold text-gray-900">
                    활동 이력 ({filteredEvents.length}개)
                  </h2>
                </div>
                
                {eventsLoading ? (
                  <div className="text-center py-16">
                    <div className="inline-block animate-spin rounded-full h-12 w-12 border-4 border-purple-200 border-t-purple-600"></div>
                    <p className="mt-4 text-gray-500">로딩 중...</p>
                  </div>
                ) : filteredEvents.length === 0 ? (
                  <div className="text-center py-12 text-gray-500">
                    활동 이력이 없습니다.
                  </div>
                ) : (
                  <div className="space-y-3 max-h-[600px] overflow-y-auto">
                    {filteredEvents.map((event, idx) => (
                      <motion.div
                        key={idx}
                        initial={{ opacity: 0, y: 10 }}
                        animate={{ opacity: 1, y: 0 }}
                        transition={{ delay: idx * 0.02 }}
                        className="border-2 border-gray-200 rounded-xl p-4 hover:border-purple-300 transition-colors"
                      >
                        <div className="flex items-start gap-3">
                          <div className="flex-1">
                            <div className="flex items-center gap-3 mb-1">
                              <span className="font-semibold text-gray-900">{event.actor}</span>
                              <span className="text-sm text-gray-500">
                                {new Date(event.created_at).toLocaleString('ko-KR', {
                                  year: 'numeric',
                                  month: 'short',
                                  day: 'numeric',
                                  hour: '2-digit',
                                  minute: '2-digit'
                                })}
                              </span>
                              <span className="px-2 py-1 bg-purple-100 text-purple-700 text-xs rounded-full">
                                {event.type.replace('Event', '')}
                              </span>
                            </div>
                            <p className="text-sm text-gray-700 mb-2">{getEventDescription(event)}</p>
                            {event.type === 'PushEvent' && event.payload.commits && (
                              <div className="mt-2 space-y-1">
                                {event.payload.commits.slice(0, 3).map((commit, i) => (
                                  <div key={i} className="text-xs text-gray-600 pl-4 border-l-2 border-purple-300">
                                    {commit.message}
                                  </div>
                                ))}
                                {event.payload.commits.length > 3 && (
                                  <div className="text-xs text-gray-500 pl-4">
                                    +{event.payload.commits.length - 3}개 더...
                                  </div>
                                )}
                              </div>
                            )}
                          </div>
                        </div>
                      </motion.div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
