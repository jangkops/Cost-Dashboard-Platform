{
  "databases": [
    {
      "name": "cost_monitoring",
      "description": "Cost monitoring database for CUR data",
      "catalog_id": "107650139384",
      "tables": [
        {
          "name": "cur_temp",
          "type": "EXTERNAL_TABLE",
          "location": "s3://mogam-or-cur-stg/cur/mogam-hourly-cur/mogam-hourly-cur",
          "input_format": "parquet",
          "columns": ["line_item_usage_start_date", "line_item_product_code", "line_item_resource_id", "line_item_unblended_cost"],
          "partition_keys": []
        },
        {
          "name": "enhanced_metrics_v2",
          "type": "EXTERNAL_TABLE",
          "location": "s3://mogam-or-cur-stg/metrics/enhanced_v2",
          "input_format": "json (JsonSerDe)",
          "columns": ["timestamp", "instance_id", "instance_type", "mode", "agent_version", "processes", "gpu_stats", "tmux_paths_loaded", "vscode_paths_loaded"],
          "partition_keys": ["year", "month", "day", "hour"],
          "projection": {
            "enabled": true,
            "storage_location_template": "s3://mogam-or-cur-stg/metrics/enhanced_v2/${year}/${month}/${day}/${hour}",
            "year_range": "2025,2030",
            "month_range": "1,12",
            "day_range": "1,31",
            "hour_range": "0,23"
          }
        },
        {
          "name": "mogam_hourly_cur",
          "type": "EXTERNAL_TABLE",
          "location": "s3://mogam-or-cur-stg/cur/mogam-hourly-cur/mogam-hourly-cur",
          "input_format": "parquet",
          "partition_keys": ["year", "month"],
          "description": "Full AWS CUR table with all billing columns"
        },
        {
          "name": "s3_inventory_mogam_or",
          "type": "EXTERNAL_TABLE",
          "location": "s3://mogam-or-cur-stg/inventory/mogam-or/project-weekly-inventory/data",
          "input_format": "parquet",
          "columns": ["bucket", "key", "size", "last_modified_date", "storage_class"],
          "partition_keys": []
        }
      ]
    },
    {
      "name": "cur_database",
      "description": "AWS Cost and Usage Report",
      "location_uri": "s3://mogam-or-cur-stg/athena-cur/",
      "catalog_id": "107650139384",
      "tables": [
        {
          "name": "mogam_hourly_cur",
          "type": "EXTERNAL_TABLE",
          "location": "s3://mogam-or-cur-stg/cur/mogam-hourly-cur/mogam-hourly-cur",
          "input_format": "parquet",
          "partition_keys": ["year", "month"]
        }
      ]
    }
  ]
}
