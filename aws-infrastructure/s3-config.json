{
  "bucket": "mogam-or-cur-stg",
  "region": "us-west-2",
  "prefixes": [
    "agent-backup/",
    "athena-results/",
    "bedrock-logs/",
    "cur/",
    "exporters/",
    "inventory-snapshots/",
    "inventory/",
    "metrics/"
  ],
  "lifecycle_rules": [
    {
      "id": "DeleteOldMetrics",
      "prefix": "metrics/",
      "status": "Enabled",
      "expiration_days": 395
    }
  ],
  "bucket_policy": {
    "statements": [
      {
        "effect": "Allow",
        "principal_service": "billingreports.amazonaws.com",
        "actions": ["s3:GetBucketAcl", "s3:GetBucketPolicy"],
        "resource": "arn:aws:s3:::mogam-or-cur-stg",
        "condition_source_account": "107650139384"
      },
      {
        "effect": "Allow",
        "principal_service": "billingreports.amazonaws.com",
        "actions": ["s3:PutObject"],
        "resource": "arn:aws:s3:::mogam-or-cur-stg/*",
        "condition_source_account": "107650139384"
      },
      {
        "sid": "S3InventoryPolicy",
        "effect": "Allow",
        "principal_service": "s3.amazonaws.com",
        "actions": ["s3:PutObject"],
        "resource": "arn:aws:s3:::mogam-or-cur-stg/inventory/*",
        "condition_source_buckets": ["mogam-or", "mogam-or-tmp", "mogam-or-user"]
      },
      {
        "sid": "AmazonBedrockLogsWrite",
        "effect": "Allow",
        "principal_service": "bedrock.amazonaws.com",
        "actions": ["s3:PutObject"],
        "resource": "arn:aws:s3:::mogam-or-cur-stg/bedrock-logs/AWSLogs/107650139384/BedrockModelInvocationLogs/*"
      }
    ]
  }
}
